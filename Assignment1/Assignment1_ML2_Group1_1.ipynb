   "source": [
    "model_bc = LinearSVC(random_state=42, max_iter=5000)\n",
    "model_bc.fit(X_bc_train_scaled, y_bc_train)\n",
    "baseline_bc = metrics.accuracy_score(y_bc_test, model_bc.predict(X_bc_test_scaled))\n",
    "print('Baseline accuracy (no projection): %.4f' % baseline_bc)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f6ea332c",
   "metadata": {},
   "source": [
    "**4. Sparse Random Projection**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 22,
   "id": "ec195f06",
   "metadata": {},
   "outputs": [],
   "source": [
    "accuracies_bc = []\n",
    "dims_bc = np.int32(np.linspace(2, 30, 15))\n",
    "for dim in dims_bc:\n",
    "    sp = SparseRandomProjection(n_components=dim, random_state=42)\n",
    "    X_proj = sp.fit_transform(X_bc_train_scaled)\n",
    "    model = LinearSVC(max_iter=5000)\n",
    "    model.fit(X_proj, y_bc_train)\n",
    "    test_proj = sp.transform(X_bc_test_scaled)\n",
    "    accuracies_bc.append(metrics.accuracy_score(y_bc_test, model.predict(test_proj)))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "21571d1d",
   "metadata": {},
   "source": [
    "**5. Ensembled Random Projection**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 23,
   "id": "ab9d50c9",
   "metadata": {},
