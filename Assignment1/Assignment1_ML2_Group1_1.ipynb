    "axes[0].plot(dims_coil, [baseline_coil] * len(dims_coil), color='r', label='Baseline')\n",
    "axes[0].plot(dims_coil, accuracies_coil, color='b', label='Single run',marker='o', markersize=4, markerfacecolor='white', markeredgewidth=1)\n",
