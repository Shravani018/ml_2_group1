    "from sklearn.random_projection import SparseRandomProjection\n",
    "from sklearn.random_projection import johnson_lindenstrauss_min_dim\n",
    "from sklearn.svm import LinearSVC\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn import metrics\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import warnings\n",
    "import io, urllib, os\n",
    "import zipfile\n",
    "from PIL import Image\n",
    "from sklearn.pipeline import make_pipeline\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "warnings.filterwarnings('ignore')\n",
    "%matplotlib inline\n",
    "np.random.seed(42) "
   ]
  },
  {
   "cell_type": "markdown",
   "id": "e33ac975",
   "metadata": {},
   "source": [
    "#### **Dataset 1: Columbia Object Image Library dataset (COIL-20)**"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "1d78b0a8",
   "metadata": {},
   "source": [
    "**1. Loading the Dataset**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "ba9a818a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "COIL-20 shape: (1440, 16384)\n",
      "Number of classes: 20\n"
     ]
    }
   ],
   "source": [
    "# Downloading the COIL-20 dataset\n",
    "response = urllib.request.urlopen('http://www.cs.columbia.edu/CAVE/databases/SLAM_coil-20_coil-100/coil-20/coil-20-proc.zip')\n",
    "zip_bytes = io.BytesIO(response.read())\n",
    "X_coil, y_coil = [], []\n",
    "with zipfile.ZipFile(zip_bytes) as zf:\n",
    "    for fname in sorted(zf.namelist()):\n",
    "        if fname.endswith('.png'):\n",
    "            label = int(fname.split('obj')[1].split('_')[0]) - 1\n",
    "            img_bytes = io.BytesIO(zf.read(fname))\n",
    "            img = Image.open(img_bytes).convert('L')\n",
    "            X_coil.append(np.array(img).flatten().astype('float32') / 255.0)\n",
    "            y_coil.append(label)\n",
    "X_coil = np.array(X_coil)\n",
    "y_coil = np.array(y_coil)\n",
    "print('COIL-20 shape:', X_coil.shape)\n",
    "print('Number of classes:', len(np.unique(y_coil)))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "8458ed6d",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1000x300 with 5 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "# Displaying some sample images from the dataset\n",
    "fig, axes = plt.subplots(1, 5, figsize=(10, 3))\n",
    "for i, ax in enumerate(axes):\n",
    "    ax.imshow(X_coil[i * 72].reshape(128, 128), cmap='gray')\n",
    "    ax.set_title('obj %d' % (y_coil[i * 72] + 1))\n",
    "    ax.axis('off')\n",
    "plt.suptitle('COIL-20 sample images (one per object)')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "ea1f9e25",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Train size: (1008, 16384)\n",
      "Test size:  (432, 16384)\n",
      "Feature dimension (original): 16384\n"
     ]
    }
   ],
   "source": [
    "# Splitting the dataset into training and testing sets (70% train, 30% test)\n",
    "X_coil_train, X_coil_test, y_coil_train, y_coil_test = train_test_split(X_coil, y_coil, test_size=0.3, random_state=42)\n",
    "print('Train size:', X_coil_train.shape)\n",
    "print('Test size: ', X_coil_test.shape)\n",
    "print('Feature dimension (original):', X_coil_train.shape[1])"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "86d3b3c4",
   "metadata": {},
   "source": [
    "**2. Johnson and Lindenstrauss Bound**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "d7ac3548",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Professors Johnson and Lindenstrauss say: k >= 6233\n"
     ]
    }
   ],
   "source": [
    "# Johnson-Lidenstrauss bound for COIL-20 (eps=0.1)\n",
    "# For n=1440 samples, dimension d=128x128=16384 (pixels)\n",
    "print('Professors Johnson and Lindenstrauss say: k >=',johnson_lindenstrauss_min_dim(len(X_coil), eps=0.1))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "e6e088de",
   "metadata": {},
   "source": [
    "**3. Getting Baseline Accuracy** "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "7423f830",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Baseline accuracy (no projection): 0.9907\n"
     ]
    }
   ],
   "source": [
    "model_coil=LinearSVC(random_state=42,max_iter=2000)\n",
    "model_coil.fit(X_coil_train, y_coil_train)\n",
    "baseline_coil=metrics.accuracy_score(y_coil_test, model_coil.predict(X_coil_test))\n",
    "print('Baseline accuracy (no projection): %.4f' % baseline_coil)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "96fcc92d",
   "metadata": {},
   "source": [
    "**4. Sparse Random Projection**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "da705e45",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Applying sparse random projection for varying dimensions\n",
    "accuracies_coil = []\n",
    "dims_coil = np.int32(np.linspace(2, 500, 20))\n",
    "for dim in dims_coil:\n",
    "    sp = SparseRandomProjection(n_components=dim, random_state=42)\n",
    "    X_proj = sp.fit_transform(X_coil_train)\n",
    "    model = LinearSVC(max_iter=2000)\n",
    "    model.fit(X_proj, y_coil_train)\n",
    "    test_proj = sp.transform(X_coil_test)\n",
    "    accuracies_coil.append(metrics.accuracy_score(y_coil_test, model.predict(test_proj)))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "2ff85c9a",
   "metadata": {},
   "source": [
    "**5. Ensembled Random Projection**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "f431589a",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Applying ensembled sparse random projection over multiple realizations\n",
    "n_realizations = 25\n",
    "accuracies_coil_ens = np.zeros((n_realizations, len(dims_coil)))\n",
    "for j, dim in enumerate(dims_coil):\n",
    "    for i in range(n_realizations):\n",
    "        sp = SparseRandomProjection(n_components=dim)\n",
    "        X_proj = sp.fit_transform(X_coil_train)\n",
    "        model = LinearSVC(max_iter=2000)\n",
    "        model.fit(X_proj, y_coil_train)\n",
    "        test_proj = sp.transform(X_coil_test)\n",
    "        accuracies_coil_ens[i, j] = metrics.accuracy_score(y_coil_test, model.predict(test_proj))\n",
    "# Averaging across realizations\n",
    "avg_accuracies_coil = accuracies_coil_ens.mean(axis=0)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "7801fc9f",
   "metadata": {},
